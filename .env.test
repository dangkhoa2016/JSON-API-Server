# ─── Test configuration ─────────────────────────────────────────────────────────
# Loaded when NODE_ENV=test
PORT=3001
DB_PATH=./storage/test.db

# Redis (optional — rate limiting falls back to in-memory if unavailable)
# REDIS_URL=
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=

# Rate limiting
RATE_LIMIT_ENABLED=true
# RATE_LIMIT_MAX=100
# RATE_LIMIT_WINDOW_MS=60000

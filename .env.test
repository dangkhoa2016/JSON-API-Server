# ─── Test configuration ─────────────────────────────────────────────────────────
# Loaded when NODE_ENV=test

# Server
PORT=3001

# SQLite database path (relative to project root)
DB_PATH=./storage/test.db

# Admin authentication key
# Set to enable protected admin routes (/api/admin/*)
ADMIN_KEY=your-test-secret-admin-key

# Redis (optional — rate limiting falls back to in-memory if unavailable)
# Option A: connection URL (takes priority over individual settings below)
# Useful for cloud providers (Upstash, Redis Cloud, etc.)
# REDIS_URL=

# Option B: individual settings
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=

# Seed data source (JSONPlaceholder-compatible API)
# Override to use a different data source for seeding
# SEED_API_BASE_URL=https://jsonplaceholder.typicode.com

# Request body size limit (bytes, default 1 MB)
# MAX_BODY_SIZE=1048576

# Default page size for pagination
# DEFAULT_PAGE_SIZE=10

# Debug: log all SQL queries to stderr
DEBUG_SQL=false

# Rate limiting
RATE_LIMIT_ENABLED=true
# RATE_LIMIT_MAX=100
# RATE_LIMIT_WINDOW_MS=60000

# ─── Production configuration ───────────────────────────────────────────────────
# Loaded when NODE_ENV=production
# Uncomment and fill in your production values:
# PORT=8080
# DB_PATH=./storage/prod.db

# REDIS_URL=redis://user:password@your-cloud-redis:6379/0
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=

# Rate limiting
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_MAX=1000
# RATE_LIMIT_WINDOW_MS=60000

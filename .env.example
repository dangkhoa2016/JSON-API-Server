# json-api-server configuration
# ────────────────────────────────────────────────────────────────────────────────
# Env files live at project root (loaded by bin/start.js via dotenv).
#
# Loading order (lowest → highest priority):
#   1. .env.{NODE_ENV}         — environment-specific overrides
#   2. .env                    — base defaults
#   3. System env vars         — highest priority (e.g. PORT=5000 node bin/start.js)
#
# NODE_ENV mapping:
#   development → .env.dev or .env.development
#   test        → .env.test
#   production  → .env.prod or .env.production

# Server
PORT=3000

# SQLite database path (relative to project root)
DB_PATH=./storage/data.db

# Redis (optional — rate limiting falls back to in-memory if unavailable)
# Option A: connection URL (takes priority over individual settings below)
# Useful for cloud providers (Upstash, Redis Cloud, etc.)
# REDIS_URL=redis://user:password@host:6379/0

# Option B: individual settings
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=your-password

# Seed data source (JSONPlaceholder-compatible API)
# Override to use a different data source for seeding
# SEED_API_BASE_URL=https://jsonplaceholder.typicode.com

# Debug: log all SQL queries to stderr
# DEBUG_SQL=true

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

{
  "name": "json-api-server",
  "version": "1.0.0",
  "description": "JSONPlaceholder-compatible REST API — Node.js built-ins only, SQLite + Redis",
  "main": "bin/start.js",
  "author": {
    "email": "i.am@dangkhoa.dev",
    "name": "Dang Khoa",
    "url": "https://dangkhoa.dev"
  },
  "scripts": {
    "db:migrate": "node src/db/migrate.js",
    "db:seed": "node src/db/seed.js",
    "db:setup": "npm run db:seed",
    "start": "node bin/start.js",
    "prod": "NODE_ENV=production-local node bin/start.js",
    "dev": "node --watch bin/start.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "rest",
    "api",
    "sqlite",
    "redis",
    "jsonplaceholder"
  ],
  "license": "MIT",
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.9",
    "dotenv": "^17.4.2",
    "vitest": "^4.1.9"
  }
}
